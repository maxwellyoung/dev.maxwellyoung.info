{
  "name": "dev-folio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "prebuild": "pnpm canon:fresh",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "test": "node --import tsx --test src/**/*.test.ts",
    "privacy:scan": "node scripts/privacy-scan.mjs",
    "canon:fresh": "node scripts/assert-canon-feed-fresh.mjs",
    "fallow": "npx --yes fallow",
    "fallow:dead-code": "npx --yes fallow dead-code",
    "fallow:dupes": "npx --yes fallow dupes",
    "fallow:health": "npx --yes fallow health",
    "fallow:audit": "npx --yes fallow audit",
    "fallow:fix:dry-run": "npx --yes fallow fix --dry-run",
    "project-images:plan": "node scripts/generate-project-images.mjs --print",
    "project-images:generate": "node scripts/generate-project-images.mjs --run"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-visually-hidden": "^1.2.7",
    "@vercel/analytics": "^1.3.1",
    "clsx": "^2.1.1",
    "fast-average-color": "^9.5.2",
    "framer-motion": "^11.3.30",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.407.0",
    "next": "^16.2.10",
    "next-themes": "^0.3.0",
    "posthog-js": "^1.399.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "swr": "^2.4.2",
    "tailwind-merge": "^2.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "playwright": "^1.57.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.10"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
